# ---------------------------------------------------------------------------
# Database
# Use 'localhost' for local dev; docker-compose overrides this to 'postgres'
# ---------------------------------------------------------------------------
DATABASE_URL=postgresql+asyncpg://chatbot:chatbot123@localhost:5432/chatbot_edu

# Variables used only by the postgres service in docker-compose
POSTGRES_USER=chatbot
POSTGRES_PASSWORD=chatbot123
POSTGRES_DB=chatbot_edu

# ---------------------------------------------------------------------------
# Groq (LLM) — required for the chat phase; must be set so pydantic-settings
# does not raise a validation error on startup
# ---------------------------------------------------------------------------
GROQ_API_KEY=replace_with_your_key
GROQ_MODEL=llama-3.3-70b-versatile

# ---------------------------------------------------------------------------
# Embeddings (local model via sentence-transformers, no API cost)
# ---------------------------------------------------------------------------
EMBEDDING_MODEL=sentence-transformers/paraphrase-multilingual-MiniLM-L12-v2

# ---------------------------------------------------------------------------
# RAG parameters
# ---------------------------------------------------------------------------
CHUNK_SIZE=500
CHUNK_OVERLAP=50
TOP_K_RESULTS=5
